/**
 * Abstract base entity class.
 *
 * @author Claude
 * @since 1.0
 */
abstract class {
    property name="id" type="numeric";
    property name="createdAt" type="date";
    property name="updatedAt" type="date";

    public function getId() {
        return variables.id;
    }

    public function setId(required numeric id) {
        variables.id = id;
        return this;
    }
}
