/**
 * Test file for variable hover functionality.
 */
class {
    property name="myProperty" type="string";

    function testLocalVariables() {
        var localVar = "hello";
        var numVar = 42;
        var typedVar = "typed";

        return localVar;
    }

    function testArguments(required string name, numeric age = 18) {
        return name & " is " & age & " years old";
    }

    function testScopedAccess() {
        var localScoped = local.someVar;
        variables.instanceVar = "instance value";
        this.publicVar = "public value";
        arguments.passedArg = "modified";

        return variables.instanceVar;
    }

    function testVariableReuse() {
        var result = "initial";
        result = "modified";
        return result;
    }

    function testObjectCreation() {
        var user = new User();
        return user.getName();
    }

    function testInferredType() {
        var count = 0;
        var name = "John";
        var isActive = true;
        var items = [];
        var data = {};

        return count;
    }
}
